# ============================================================
# Twenty self-hosted deployment — environment configuration
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env && nano .env
# ============================================================

# Your domain (must have an A record pointing to this VM's IP)
DOMAIN=crm.yourdomain.com

# Full URL used by the server and baked into the frontend build.
# Must match DOMAIN with the https:// scheme.
SERVER_URL=https://crm.yourdomain.com

# Let's Encrypt notification address (used only for expiry warnings)
ACME_EMAIL=admin@yourdomain.com

# Random secret — generate with: openssl rand -base64 32
APP_SECRET=replace_me_with_a_random_string

# Postgres credentials (internal — not exposed outside Docker)
PG_DATABASE_USER=twenty
PG_DATABASE_PASSWORD=replace_me_with_a_strong_password
PG_DATABASE_NAME=default

# Storage backend ('local' stores files inside the container volume)
STORAGE_TYPE=local

# S3-compatible storage (only needed when STORAGE_TYPE=s3)
# STORAGE_S3_REGION=eu-west-3
# STORAGE_S3_NAME=my-bucket
# STORAGE_S3_ENDPOINT=
